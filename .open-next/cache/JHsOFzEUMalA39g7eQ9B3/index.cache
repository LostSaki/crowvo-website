hmn.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"sticky top-0 z-50 border-b border-slate-200/80 bg-white/85 backdrop-blur-xl dark:border-white/10 dark:bg-[#0b0d14]/85\"><div class=\"mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6\"><a class=\"text-lg font-bold tracking-tight text-foreground\" href=\"/\">Crowvo</a><nav class=\"hidden gap-6 text-sm text-muted md:flex\"><a class=\"transition hover:text-foreground\" href=\"/\">Home</a><a class=\"transition hover:text-foreground\" href=\"/about\">About</a><a class=\"transition hover:text-foreground\" href=\"/investors\">Investors</a><a class=\"transition hover:text-foreground\" href=\"/admin\">Admin</a></nav><div class=\"flex items-center gap-2\"><button class=\"rounded-full border border-slate-300 bg-white px-3 py-1 text-xs font-medium text-foreground shadow-sm backdrop-blur hover:bg-slate-100 dark:border-white/20 dark:bg-white/10 dark:hover:bg-white/20\" type=\"button\" aria-label=\"Toggle theme\">Light<!-- --> mode</button><a data-analytics-event=\"cta_start_hub_click\" data-analytics-cta=\"navbar_start_hub\" class=\"rounded-full bg-gradient-to-r from-[#5865F2] to-[#7c5cff] px-4 py-2 text-xs font-semibold text-white transition hover:scale-105\" href=\"/#waitlist\">Start Your Hub</a></div></div></header><main class=\"flex-1\"><div class=\"mx-auto flex w-full max-w-6xl flex-col gap-14 px-4 py-12 sm:px-6\"><section style=\"opacity:0;transform:translateY(24px)\"><div class=\"grid items-start gap-8 lg:grid-cols-[1.1fr_0.9fr]\"><div class=\"space-y-6\"><p class=\"inline-flex rounded-full border border-indigo-300/40 bg-indigo-100 px-3 py-1 text-xs font-semibold tracking-[0.14em] text-indigo-700 dark:border-indigo-300/30 dark:bg-indigo-300/10 dark:text-indigo-200\">LIVE COMMUNITIES · PRIVATE BY DEFAULT</p><h1 class=\"text-4xl font-semibold leading-tight tracking-tight sm:text-6xl\">Social velocity of X.<br/>Trusted community depth of Discord.</h1><p class=\"max-w-2xl text-base text-muted sm:text-lg\">Crowvo is community-first social infrastructure. Your hub becomes the place people talk, plan, and mobilize together, with events as a native action layer.</p><div id=\"waitlist\"><form class=\"w-full rounded-2xl border border-slate-200/80 bg-white/95 p-4 shadow-sm backdrop-blur dark:border-white/15 dark:bg-[#151a2b]/85\"><label for=\"email\" class=\"mb-2 block text-sm text-muted\">Get early access before public launch</label><div class=\"flex flex-col gap-3 sm:flex-row\"><input id=\"email\" type=\"email\" required=\"\" placeholder=\"you@startup.com\" class=\"h-12 flex-1 rounded-xl border border-slate-300 bg-white px-4 text-sm text-slate-900 outline-none ring-[#5865F2] focus:ring-2 dark:border-white/20 dark:bg-black/40 dark:text-white\" value=\"\"/><button type=\"submit\" data-analytics-event=\"cta_waitlist_click\" data-analytics-cta=\"join_waitlist_form\" class=\"h-12 rounded-xl bg-gradient-to-r from-[#5865F2] to-[#7c5cff] px-6 text-sm font-semibold text-white transition hover:scale-[1.02] disabled:opacity-70\">Join Waitlist</button></div><p class=\"mt-2 text-xs text-muted\">Limited beta seats. Founding members get priority access.</p></form></div><div class=\"flex flex-wrap gap-3\"><a href=\"#waitlist\" data-analytics-event=\"cta_waitlist_click\" data-analytics-cta=\"hero_join_waitlist\" class=\"inline-flex rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-semibold text-slate-900 transition hover:bg-slate-100 dark:border-white/20 dark:bg-transparent dark:text-white dark:hover:bg-white/10\">Join Waitlist</a><a href=\"/investors\" data-analytics-event=\"cta_request_deck_click\" data-analytics-cta=\"hero_request_deck\" class=\"inline-flex rounded-full border border-indigo-300/50 bg-indigo-100 px-4 py-2 text-xs font-semibold text-indigo-700 transition hover:bg-indigo-200 dark:border-indigo-300/30 dark:bg-indigo-300/10 dark:text-indigo-200 dark:hover:bg-indigo-300/20\">Request Deck</a></div><div class=\"grid gap-3 text-xs text-muted sm:grid-cols-3\"><p class=\"rounded-xl border border-slate-200/80 bg-white/85 px-3 py-2 dark:border-white/10 dark:bg-white/5\">23,948 waitlist joins</p><p class=\"rounded-xl border border-slate-200/80 bg-white/85 px-3 py-2 dark:border-white/10 dark:bg-white/5\">61 city ambassadors</p><p class=\"rounded-xl border border-slate-200/80 bg-white/85 px-3 py-2 dark:border-white/10 dark:bg-white/5\">17 pilot communities</p></div></div><div class=\"space-y-4\"><div class=\"rounded-3xl border border-slate-200/80 bg-white/90 p-4 shadow-sm dark:border-white/15 dark:bg-[#151a2b]/85\"><p class=\"text-xs font-semibold tracking-wider text-indigo-500 dark:text-indigo-300\">LIVE FEED</p><div class=\"mt-3 space-y-3\"><div class=\"rounded-xl border border-slate-200/80 bg-white p-3 dark:border-white/10 dark:bg-black/30\"><p class=\"text-sm font-semibold\">@brooklynafterdark</p><p class=\"mt-1 text-xs text-muted\">New member intros thread is live. 84 replies in 20 minutes.</p></div><div class=\"rounded-xl border border-slate-200/80 bg-white p-3 dark:border-white/10 dark:bg-black/30\"><p class=\"text-sm font-semibold\">@foundercollective</p><p class=\"mt-1 text-xs text-muted\">Weekly voice townhall starts in 12m. Event sprint planning room open.</p></div></div></div><div class=\"rounded-3xl border border-slate-200/80 bg-slate-950 p-4 text-white shadow-sm dark:border-white/15\"><p class=\"text-xs font-semibold tracking-wider text-indigo-200\">CROWVO HUB · PRIVATE CHANNELS</p><div class=\"mt-3 space-y-2 text-sm text-indigo-100/90\"><p># event-chat · 248 online</p><p># ticket-drops · 84 online</p><p># feedback-loop · 52 online</p></div></div></div></div></section><section style=\"opacity:0;transform:translateY(24px)\"><div class=\"mb-4 text-center text-xs font-semibold tracking-[0.2em] text-muted\">POST · CHAT · CONVERT</div><div class=\"grid gap-4 md:grid-cols-4\"><article class=\"rounded-2xl border border-slate-200/80 bg-white/85 p-5 shadow-sm dark:border-white/15 dark:bg-white/5\"><h2 class=\"mb-2 text-lg font-semibold\">Community Hubs</h2><p class=\"text-sm text-muted\">Private spaces with channels, roles, and moderation controls built for trust.</p></article><article class=\"rounded-2xl border border-slate-200/80 bg-white/85 p-5 shadow-sm dark:border-white/15 dark:bg-white/5\"><h2 class=\"mb-2 text-lg font-semibold\">Live Feed + Chat</h2><p class=\"text-sm text-muted\">Post updates, react in real time, and keep momentum without context switching.</p></article><article class=\"rounded-2xl border border-slate-200/80 bg-white/85 p-5 shadow-sm dark:border-white/15 dark:bg-white/5\"><h2 class=\"mb-2 text-lg font-semibold\">Voice + Presence</h2><p class=\"text-sm text-muted\">See who is active, hop into voice rooms fast, and coordinate with your core group.</p></article><article class=\"rounded-2xl border border-slate-200/80 bg-white/85 p-5 shadow-sm dark:border-white/15 dark:bg-white/5\"><h2 class=\"mb-2 text-lg font-semibold\">Event Layer</h2><p class=\"text-sm text-muted\">Discovery, RSVP, ticketing, and attendance tools are native to each community.</p></article></div></section><section style=\"opacity:0;transform:translateY(24px)\"><div class=\"rounded-3xl border border-slate-200/80 bg-white/85 p-6 shadow-sm dark:border-white/15 dark:bg-white/5\"><h3 class=\"text-2xl font-semibold\">Community first. Events as a native action.</h3><div class=\"mt-5 grid gap-4 md:grid-cols-3\"><div class=\"rounded-2xl border border-slate-200/80 bg-white/65 p-4 dark:border-white/15 dark:bg-transparent\"><p class=\"text-xs text-indigo-600 dark:text-indigo-200\">Step <!-- -->1</p><p class=\"mt-2 text-sm text-muted\">Start or join a private hub around your city, creator, or niche.</p></div><div class=\"rounded-2xl border border-slate-200/80 bg-white/65 p-4 dark:border-white/15 dark:bg-transparent\"><p class=\"text-xs text-indigo-600 dark:text-indigo-200\">Step <!-- -->2</p><p class=\"mt-2 text-sm text-muted\">Build daily social activity through feed posts, chat, and voice rooms.</p></div><div class=\"rounded-2xl border border-slate-200/80 bg-white/65 p-4 dark:border-white/15 dark:bg-transparent\"><p class=\"text-xs text-indigo-600 dark:text-indigo-200\">Step <!-- -->3</p><p class=\"mt-2 text-sm text-muted\">Convert momentum into real events with built-in discovery and ticket actions.</p></div></div></div></section><section style=\"opacity:0;transform:translateY(24px)\"><div class=\"grid gap-5 md:grid-cols-3\"><div class=\"rounded-3xl border border-slate-200/80 bg-gradient-to-b from-[#5865F2]/10 to-[#7c5cff]/5 p-4 dark:border-white/15\"><div class=\"h-64 rounded-2xl border border-slate-300/80 bg-white/70 p-3 dark:border-white/10 dark:bg-black/30\"><p class=\"text-sm text-muted\">UI Preview <!-- -->1</p></div></div><div class=\"rounded-3xl border border-slate-200/80 bg-gradient-to-b from-[#5865F2]/10 to-[#7c5cff]/5 p-4 dark:border-white/15\"><div class=\"h-64 rounded-2xl border border-slate-300/80 bg-white/70 p-3 dark:border-white/10 dark:bg-black/30\"><p class=\"text-sm text-muted\">UI Preview <!-- -->2</p></div></div><div class=\"rounded-3xl border border-slate-200/80 bg-gradient-to-b from-[#5865F2]/10 to-[#7c5cff]/5 p-4 dark:border-white/15\"><div class=\"h-64 rounded-2xl border border-slate-300/80 bg-white/70 p-3 dark:border-white/10 dark:bg-black/30\"><p class=\"text-sm text-muted\">UI Preview <!-- -->3</p></div></div></div></section><section style=\"opacity:0;transform:translateY(24px)\"><div class=\"space-y-4\"><div class=\"rounded-3xl border border-slate-200/80 bg-white/85 p-6 shadow-sm dark:border-white/15 dark:bg-white/5\"><h3 class=\"text-2xl font-semibold\">What early communities say</h3><p class=\"mt-3 text-muted\">“Our members now hang out daily in one place, and when we launch an event it fills faster because the community is already active.”</p><p class=\"mt-1 text-xs text-indigo-600 dark:text-indigo-200\">— Community Host, Brooklyn</p></div></div></section><section style=\"opacity:0;transform:translateY(24px)\"><div class=\"rounded-3xl border border-indigo-400/30 bg-gradient-to-r from-indigo-500/10 to-violet-500/10 p-6 text-center\"><h3 class=\"text-2xl font-semibold\">Build your community home, then turn energy into attendance.</h3><p class=\"mx-auto mt-2 max-w-2xl text-muted\">Launch your private Crowvo hub now and secure founding perks before public rollout.</p><div class=\"mt-4 flex flex-wrap items-center justify-center gap-3\"><a href=\"#waitlist\" data-analytics-event=\"cta_start_hub_click\" data-analytics-cta=\"final_start_founding_hub\" class=\"inline-flex rounded-full bg-gradient-to-r from-[#5865F2] to-[#7c5cff] px-6 py-3 text-sm font-semibold text-white\">Start Founding Hub</a><a href=\"/investors\" data-analytics-event=\"cta_request_deck_click\" data-analytics-cta=\"final_request_deck\" class=\"inline-flex rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-100 dark:border-white/20 dark:bg-transparent dark:text-white dark:hover:bg-white/10\">Request Deck</a></div></div></section></div><!--$--><!--/$--></main><footer class=\"border-t border-slate-200/80 bg-white/80 dark:border-white/10 dark:bg-[#0b0d14]/60\"><div class=\"mx-auto flex max-w-6xl flex-col gap-2 px-4 py-8 text-sm text-muted sm:px-6 md:flex-row md:items-center md:justify-between\"><p>© <!-- -->2026<!-- --> Crowvo. Social communities first, events built in.</p><p>Built for founders, creators, and city explorers.</p></div></footer><script src=\"/_next/static/chunks/0y_wgo4lu8n.h.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[58381,[\\\"/_next/static/chunks/0bh~-j30_vp8c.js\\\",\\\"/_next/static/chunks/0ex5okdzjd8u7.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"AnalyticsProvider\\\"]\\n3:I[22016,[\\\"/_next/static/chunks/0bh~-j30_vp8c.js\\\",\\\"/_next/s